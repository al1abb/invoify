# SMTP transport for sending invoice emails
# Option A (recommended): full connection string
SMTP_URL=

# Option B: explicit host/port credentials
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional sender shown in recipient inbox
SMTP_FROM="Invoify <no-reply@example.com>"
# Optional split sender fields (used when SMTP_FROM is not set)
SMTP_FROM_NAME=
SMTP_FROM_EMAIL=

# Optional sync provider abstraction selector
# local (default) | noop-cloud | supabase-rest
NEXT_PUBLIC_INVOICE_SYNC_PROVIDER=local

# Sync pacing and payload guards (free-plan friendly defaults)
NEXT_PUBLIC_SYNC_DEBOUNCE_MS=5000
NEXT_PUBLIC_SYNC_MAX_INVOICES=250
NEXT_PUBLIC_SYNC_MAX_TEMPLATES=100
NEXT_PUBLIC_SYNC_MAX_PAYLOAD_BYTES=524288
NEXT_PUBLIC_SYNC_RETRY_MAX_ATTEMPTS=3
NEXT_PUBLIC_SYNC_RETRY_BASE_DELAY_MS=1000

# Required only for supabase-rest provider
# Example Supabase URL: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional Sentry monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_TRACES_SAMPLE_RATE=0.1
# Use development locally, beta for beta deployments, production for production
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ENVIRONMENT=development
# Optional release identifier shown in Sentry (example: v0.3.0-beta.1)
SENTRY_RELEASE=

# Required only if uploading source maps during build
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
