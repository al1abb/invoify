# Gmail account used to send invoice emails
NODEMAILER_EMAIL=your_email@example.com

# Gmail App Password (not your normal account password)
NODEMAILER_PW=your_gmail_app_password

# Optional sync provider abstraction selector
# local (default) | noop-cloud | supabase-rest
NEXT_PUBLIC_INVOICE_SYNC_PROVIDER=local

# Sync pacing and payload guards (free-plan friendly defaults)
NEXT_PUBLIC_SYNC_DEBOUNCE_MS=5000
NEXT_PUBLIC_SYNC_MAX_INVOICES=250
NEXT_PUBLIC_SYNC_MAX_TEMPLATES=100
NEXT_PUBLIC_SYNC_MAX_PAYLOAD_BYTES=524288

# Required only for supabase-rest provider
# Example ingest URL: https://<project-ref>.supabase.co/functions/v1/invoice-sync
NEXT_PUBLIC_SYNC_INGEST_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
